// ============================================
// TAD DOOH Platform - Prisma Schema
// ============================================
// Database schema for PostgreSQL
// ============================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// USERS (Administradores del sistema)
// ============================================

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  role      String @default("ADMIN")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  campaigns Campaign[]
  
  @@map("users")
}



// ============================================
// DEVICES (Tablets en taxis)
// ============================================

model Device {
  id            String    @id @default(uuid())
  deviceId      String    @unique @map("device_id")
  name          String?
  taxiNumber    String?   @map("taxi_number")
  city          String?
  status        String @default("ACTIVE")
  lastSync      DateTime? @map("last_sync")
  lastHeartbeat DateTime? @map("last_heartbeat")
  batteryLevel  Int?      @map("battery_level")
  storageUsed   BigInt?   @map("storage_used")
  storageTotal  BigInt?   @map("storage_total")
  appVersion    String?   @map("app_version")
  authToken     String?   @map("auth_token")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt      @map("updated_at")

  fleet         String?
  lastSeen      DateTime? @map("last_seen")
  storageFree   String?   @map("storage_free")
  lastPlayback  DateTime? @map("last_playback")
  playerStatus  String?   @map("player_status")
  lastSyncHash  String?   @map("last_sync_hash")
  lastSyncAt    DateTime? @map("last_sync_at")
  lastOnline    DateTime? @map("last_online")
  lastSyncSuccess Boolean? @map("last_sync_success")

  events         AnalyticsEvent[]
  commands       DeviceCommand[]
  campaignMetrics CampaignMetric[]
  heartbeats      DeviceHeartbeat[]
  playbackEvents  PlaybackEvent[]
  assignedCampaigns PlaylistItem[]
  driver          Driver?
  
  @@map("devices")
  @@index([status])
  @@index([lastSync])
  @@index([city])
  @@index([lastSeen])
}



// ============================================
// CAMPAIGNS (Campañas publicitarias)
// ============================================

model Campaign {
  id          String   @id @default(uuid())
  name        String
  advertiser  String
  description String?
  status      String @default("DRAFT")
  active      Boolean  @default(true)
  startDate   DateTime @map("start_date")
  endDate     DateTime @map("end_date")
  version     Int      @default(1)
  targetCities String @default("[]") @map("target_cities")
  targetFleets String @default("[]") @map("target_fleets")
  priority    Int      @default(0)
  targetImpressions Int @default(0) @map("target_impressions")
  budget      Float @default(0)
  createdById String?  @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt      @map("updated_at")

  createdBy User?      @relation(fields: [createdById], references: [id])
  playlists Playlist[]
  metrics   CampaignMetric[]
  videos       Video[]
  mediaAssets  MediaAsset[]
  targets      PlaylistItem[]
  
  @@map("campaigns")
  @@index([active])
  @@index([status])
  @@index([startDate, endDate])
}



// ============================================
// PLAYLISTS (Listas de reproducción)
// ============================================

model Playlist {
  id        String   @id @default(uuid())
  campaignId String  @map("campaign_id")
  name      String
  loopType  String @default("SEQUENTIAL")
  createdAt DateTime @default(now()) @map("created_at")

  campaign Campaign        @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  
  @@map("playlists")
}



// ============================================
// PLAYLIST ITEMS (Items en playlist)
// ============================================

// ============================================
// CAMPAIGN TARGETS (Asignación manual a dispositivos)
// ============================================

model PlaylistItem {
  campaignId String @map("campaign_id")
  deviceId   String @map("device_id")

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  device   Device   @relation(fields: [deviceId], references: [deviceId], onDelete: Cascade)

  @@id([campaignId, deviceId])
  @@map("playlist_items")
}

// ============================================
// MEDIA (Archivos de video/imagen)
// ============================================

model Media {
  id              String   @id @default(uuid())
  filename        String
  originalFilename String? @map("original_filename")
  mimeType        String  @map("mime_type")
  fileSize        BigInt  @map("file_size")
  durationSeconds Int?    @map("duration_seconds")
  width           Int?
  height          Int?
  storageKey      String  @map("storage_key")
  cdnUrl          String? @map("cdn_url")
  hashMd5         String  @map("hash_md5")
  hashSha256      String  @map("hash_sha256")
  status          String @default("PROCESSING")
  createdAt       DateTime @default(now()) @map("created_at")
  
  @@map("media")
  @@index([status])
}



// ============================================
// ANALYTICS EVENTS (Eventos de analytics)
// ============================================

model AnalyticsEvent {
  id          String   @id @default(uuid())
  deviceId    String   @map("device_id")
  campaignId  String   @map("campaign_id")
  mediaId     String?  @map("media_id")
  eventType   String   @map("event_type")
  eventData   String?    @map("event_data")
  timestamp   DateTime @default(now())
  occurredAt  DateTime @map("occurred_at")
  receivedAt  DateTime @default(now()) @map("received_at")
  processed   Boolean  @default(false)

  device Device? @relation(fields: [deviceId], references: [deviceId])
  
  @@map("analytics_events")
  @@index([deviceId])
  @@index([campaignId])
  @@index([eventType])
  @@index([occurredAt])
  @@index([processed])
}

// ============================================
// CAMPAIGN METRICS (Métricas pre-computadas)
// ============================================

model CampaignMetric {
  id               BigInt   @id @default(autoincrement())
  campaignId       String   @map("campaign_id")
  deviceId         String?  @map("device_id")
  date             DateTime
  city             String?
  totalImpressions Int      @default(0) @map("total_impressions")
  totalCompletions Int      @default(0) @map("total_completions")
  totalErrors      Int      @default(0) @map("total_errors")
  uniqueDevices    Int      @default(0) @map("unique_devices")
  avgCompletionRate Float? @map("avg_completion_rate")
  createdAt        DateTime @default(now()) @map("created_at")

  campaign Campaign? @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  device   Device?  @relation(fields: [deviceId], references: [id])
  
  @@map("campaign_metrics")
  @@index([campaignId])
  @@index([date])
  @@unique([campaignId, date, city])
}

// ============================================
// DEVICE COMMANDS (Comandos remotos)
// ============================================

model DeviceCommand {
  id           String        @id @default(uuid())
  deviceId     String        @map("device_id")
  commandType  String        @map("command_type")
  commandParams String?        @map("command_params")
  status       String @default("PENDING")
  createdAt    DateTime      @default(now()) @map("created_at")
  executedAt   DateTime?     @map("executed_at")
  result       String?
  expiresAt    DateTime?     @map("expires_at")

  device Device @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  
  @@map("device_commands")
  @@index([deviceId])
  @@index([status])
}



// ============================================
// NEW MODELS FOR V1
// ============================================

model Video {
  id          String   @id @default(uuid())
  campaignId  String   @map("campaign_id")
  title       String
  url         String
  duration    Int
  fileSize    Int?     @map("file_size")
  mimeType    String?  @map("mime_type")
  createdAt   DateTime @default(now()) @map("created_at")
  uploadedAt  DateTime @default(now()) @map("uploaded_at")

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@map("videos")
}

model DeviceHeartbeat {
  id           String   @id @default(uuid())
  deviceId     String   @map("device_id")
  batteryLevel Int?     @map("battery_level")
  storageFree  String?  @map("storage_free")
  timestamp    DateTime @default(now())

  // Using deviceId as string field, relation works if we map it to the Device unique deviceId or ID. 
  // It's usually better to map to Device ID. 
  // Wait, device_id from payload is e.g. "taxi-9wu77o406". Let's link it to Device.deviceId as relation?
  // Our Schema: Device has `id` and `deviceId` (unique).
  // Standard relational is by `deviceId` in Device.id or Device.deviceId.
  device       Device   @relation(fields: [deviceId], references: [deviceId], onDelete: Cascade)

  @@map("device_heartbeats")
  @@index([deviceId])
}

model PlaybackEvent {
  id         String   @id @default(uuid())
  deviceId   String   @map("device_id")
  eventType  String   @map("event_type")
  videoId    String   @map("video_id")
  timestamp  DateTime @default(now())

  device     Device   @relation(fields: [deviceId], references: [deviceId], onDelete: Cascade)

  @@map("playback_events")
  @@index([deviceId])
}

model MediaAsset {
  id          String   @id @default(uuid())
  campaignId  String   @map("campaign_id")
  type        String
  filename    String
  url         String
  fileSize    Int      @map("file_size")
  checksum    String
  duration    Int?
  version     Int      @default(1)
  createdAt   DateTime @default(now()) @map("created_at")

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@map("media_assets")
  @@index([campaignId])
}

model Fleet {
  id        String   @id @default(uuid())
  name      String   @unique
  city      String?
  createdAt DateTime @default(now()) @map("created_at")

  @@map("fleets")
}

// ============================================
// DRIVERS (Choferes de taxis)
// ============================================

model Driver {
  id            String   @id @default(uuid())
  fullName      String   @map("full_name")
  phone         String   @unique  // WhatsApp number
  licensePlate  String?  @map("license_plate")
  taxiNumber    String?  @map("taxi_number")
  deviceId      String?  @unique @map("device_id") // FK to Device.deviceId
  status        String   @default("ACTIVE") // ACTIVE, SUSPENDED, INACTIVE
  onboardedAt   DateTime @default(now()) @map("onboarded_at")
  blockedAt     DateTime? @map("blocked_at")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  device        Device?  @relation(fields: [deviceId], references: [deviceId])
  subscriptions Subscription[]

  @@map("drivers")
  @@index([status])
  @@index([phone])
}

// ============================================
// SUBSCRIPTIONS (Suscripciones y pagos)
// ============================================

model Subscription {
  id            String   @id @default(uuid())
  driverId      String   @map("driver_id")
  plan          String   // ANNUAL, MONTHLY
  amount        Float    // RD$ amount (6000 or 500)
  status        String   @default("ACTIVE") // ACTIVE, EXPIRED, SUSPENDED, CANCELLED
  startDate     DateTime @default(now()) @map("start_date")
  dueDate       DateTime @map("due_date")
  paidDate      DateTime? @map("paid_date")
  paymentMethod String?  @map("payment_method") // CASH, TRANSFER, CARD
  paymentRef    String?  @map("payment_ref")    // Receipt or reference number
  notes         String?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  driver        Driver   @relation(fields: [driverId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
  @@index([driverId])
  @@index([status])
  @@index([dueDate])
}

