{
  "name": "tad-dooh-platform",
  "version": "0.1.0",
  "description": "Taxi Advertising Distribution - Digital Out-Of-Home Network",
  "author": "TAD Dominicana",
  "license": "PROPRIETARY",
  "private": true,
  "workspaces": [
    "admin-dashboard",
    "backend"
  ],
  "scripts": {
    "dev:backend": "cd backend && npm run start:dev",
    "dev:tablet": "cd tablet-player && python -m http.server 8080",
    "dev:admin": "npm run dev -w admin-dashboard",
    "install:all": "npm install",
    "build": "next build",
    "build:backend": "cd backend && npm run build",
    "deploy:vercel": "node devops/deploy-vercel.js"
  },
  "keywords": [
    "dooh",
    "advertising",
    "taxi",
    "digital-signage",
    "offline-first"
  ],
  "dependencies": {
    "@nestjs/common": "^10.3.0",
    "@nestjs/config": "^3.1.1",
    "@nestjs/core": "^10.3.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.4.22",
    "@nestjs/swagger": "^7.1.17",
    "@nestjs/throttler": "^5.1.1",
    "@prisma/client": "^5.9.1",
    "@supabase/supabase-js": "^2.99.1",
    "bcrypt": "^5.1.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.4",
    "express": "^4.18.2",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "prisma": "^5.9.1",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "reflect-metadata": "^0.1.14",
    "rxjs": "^7.8.1",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.0",
    "postcss": "^8.4.31"
  }
}
