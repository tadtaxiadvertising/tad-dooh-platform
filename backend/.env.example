# ============================================
# TAD DOOH Platform - Environment Variables
# ============================================
# Copia este archivo a .env y configura tus credenciales
# ============================================

# --------------------------------------------
# Application
# --------------------------------------------
NODE_ENV=development
PORT=3000
API_PREFIX=/api

# --------------------------------------------
# Database (PostgreSQL - Supabase)
# --------------------------------------------
DATABASE_URL="postgresql://<supabase-connection-string>"

# Node Environment
NODE_ENV=production

# --------------------------------------------
# Supabase (Auth + DB)
# --------------------------------------------
SUPABASE_URL="https://your-project-id.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="eyJh..." # MUST BE THE SERVICE ROLE KEY (JWT FORMAT)
SUPABASE_JWT_SECRET="your-jwt-secret" # Used for local token verification

# --------------------------------------------
# Redis (Cache + Queue)
# --------------------------------------------
REDIS_URL=redis://localhost:6379

# --------------------------------------------
# Cloud Storage Configuration (S3 / R2 / DO Spaces)
# --------------------------------------------
STORAGE_ENDPOINT="https://<account_id>.r2.cloudflarestorage.com"
STORAGE_ACCESS_KEY="<your_access_key>"
STORAGE_SECRET_KEY="<your_secret_key>"
STORAGE_BUCKET="tad-media"
STORAGE_CDN_URL="https://cdn.tad.com" # Optional, maps payload responses directly

# --------------------------------------------
# JWT Authentication
# --------------------------------------------
JWT_SECRET=cambia-esto-por-una-key-segura-de-al-menos-32-caracteres
JWT_EXPIRES_IN=30d
REFRESH_TOKEN_EXPIRES_IN=90d

# --------------------------------------------
# Storage (S3 Compatible - DigitalOcean Spaces)
# --------------------------------------------
STORAGE_ENDPOINT=nyc3.digitaloceanspaces.com
STORAGE_REGION=nyc3
STORAGE_BUCKET=tad-dooh-media
STORAGE_KEY=tu-access-key-aqui
STORAGE_SECRET=tu-secret-key-aqui
STORAGE_PUBLIC_URL=https://tad-dooh-media.nyc3.digitaloceanspaces.com

# --------------------------------------------
# CDN (Cloudflare)
# --------------------------------------------
CDN_URL=https://cdn.tad.do

# --------------------------------------------
# Email (SendGrid / SMTP)
# --------------------------------------------
# SendGrid
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxx

# O SMTP (Gmail con App Password / SendGrid)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tad.taxiadvertising@gmail.com
SMTP_PASSWORD=tu-app-password
SMTP_FROM=TAD Advertising <no-reply@tad.do>

# --------------------------------------------
# Tablet Player
# --------------------------------------------
TABLET_SYNC_WINDOW_MINUTES=10
TABLET_HEARTBEAT_INTERVAL_SECONDS=300
TABLET_ANALYTICS_BATCH_SIZE=100

# --------------------------------------------
# Rate Limiting
# --------------------------------------------
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# --------------------------------------------
# Logging
# --------------------------------------------
LOG_LEVEL=debug
LOG_FORMAT=dev

# --------------------------------------------
# CORS
# --------------------------------------------
CORS_ORIGINS=http://localhost:3001,https://tad-dooh-dashboard.vercel.app

# --------------------------------------------
# Monitoring (Optional)
# --------------------------------------------
SENTRY_DSN=https://xxxxx@sentry.io/xxxxx
GRAFANA_URL=https://grafana.tad.do
PROMETHEUS_URL=https://prometheus.tad.do
GOOGLE_CLIENT_ID=1081552204265-g1ff5hpf428t1ufe6rogt451om423c2o.apps.googleusercontent.com
