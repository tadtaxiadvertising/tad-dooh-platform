{
  "version": 2,
  "builds": [
    {
      "src": "backend/api/index.ts",
      "use": "@vercel/node"
    },
    {
      "src": "admin-dashboard/package.json",
      "use": "@vercel/next"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "backend/api/index.ts"
    },
    {
      "src": "/_next/(.*)",
      "dest": "admin-dashboard/_next/$1"
    },
    {
      "src": "/(.*)",
      "dest": "admin-dashboard/$1"
    }
  ]
}
