{
  "name": "tad-dooh-platform",
  "version": "0.1.0",
  "description": "Taxi Advertising Distribution - Digital Out-Of-Home Network",
  "author": "TAD Dominicana",
  "license": "PROPRIETARY",
  "private": true,
  "workspaces": [
    "admin-dashboard",
    "backend"
  ],
  "scripts": {
    "dev:backend": "cd backend && npm run start:dev",
    "dev:tablet": "cd tablet-player && python -m http.server 8080",
    "install:all": "npm install",
    "build": "npm run install:all && npm run build -w admin-dashboard && npm run build -w backend",
    "build:backend": "cd backend && npm run build",
    "deploy:vercel": "node devops/deploy-vercel.js"
  },
  "keywords": [
    "dooh",
    "advertising",
    "taxi",
    "digital-signage",
    "offline-first"
  ],
  "dependencies": {
    "@tailwindcss/postcss": "^4",
    "tailwindcss": "^4",
    "postcss": "^8",
    "autoprefixer": "^10",
    "@tailwindcss/next": "^4"
  }
}
