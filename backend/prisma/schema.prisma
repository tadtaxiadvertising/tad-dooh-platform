generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String     @id @default(uuid())
  email     String     @unique
  password  String
  name      String
  role      String     @default("ADMIN")
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  campaigns Campaign[]

  @@map("users")
}

model Device {
  id                String            @id @default(uuid())
  deviceId          String            @unique @map("device_id")
  name              String?
  taxiNumber        String?           @map("taxi_number")
  city              String?
  status            String            @default("ACTIVE")
  lastSync          DateTime?         @map("last_sync")
  lastHeartbeat     DateTime?         @map("last_heartbeat")
  batteryLevel      Int?              @default(100) @map("battery_level")
  lastLat           Float?            @map("last_lat")
  lastLng           Float?            @map("last_lng")
  isOnline          Boolean           @default(false) @map("is_online")
  storageUsed       BigInt?           @map("storage_used")
  storageTotal      BigInt?           @map("storage_total")
  appVersion        String?           @map("app_version")
  authToken         String?           @map("auth_token")
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")
  fleet             String?
  lastSeen          DateTime?         @map("last_seen")
  storageFree       String?           @map("storage_free")
  lastPlayback      DateTime?         @map("last_playback")
  playerStatus      String?           @map("player_status")
  lastSyncHash      String?           @map("last_sync_hash")
  lastSyncAt        DateTime?         @map("last_sync_at")
  lastOnline        DateTime?         @map("last_online")
  lastSyncSuccess   Boolean?          @map("last_sync_success")
  driverId          String?           @map("driver_id")
  events            AnalyticsEvent[]
  campaignMetrics   CampaignMetric[]
  campaigns         DeviceCampaign[]
  commands          DeviceCommand[]
  heartbeats        DeviceHeartbeat[]
  driver            Driver?           @relation(fields: [driverId], references: [id])
  locations         DriverLocation[]
  playbackEvents    PlaybackEvent[]
  assignedCampaigns PlaylistItem[]
  subscriptions     Subscription[]

  @@index([status])
  @@index([lastSync])
  @@index([city])
  @@index([lastSeen])
  @@index([driverId])
  @@map("devices")
}

model Campaign {
  id                String           @id @default(uuid())
  name              String
  advertiser        String
  advertiserId      String?          @map("advertiser_id")
  description       String?
  status            String           @default("DRAFT")
  active            Boolean          @default(true)
  startDate         DateTime         @map("start_date")
  endDate           DateTime         @map("end_date")
  version           Int              @default(1)
  isGlobal          Boolean          @default(false) @map("is_global")
  targetAll         Boolean          @default(true) @map("target_all")
  targetCities      String           @default("[]") @map("target_cities")
  targetCity        String           @default("Global") @map("target_city")
  targetFleets      String           @default("[]") @map("target_fleets")
  priority          Int              @default(0)
  targetImpressions Int              @default(0) @map("target_impressions")
  budget            Float            @default(0)
  targetUrl         String?          @map("target_url")
  createdById       String?          @map("created_by")
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")
  facebook          String?
  instagram         String?
  pedidosYaUrl      String?          @map("pedidos_ya_url")
  uberEatsUrl       String?          @map("uber_eats_url")
  websiteUrl        String?          @map("website_url")
  whatsapp          String?
  category          String?          @default("General")
  metrics           CampaignMetric[]
  advertiserRef     Advertiser?      @relation(fields: [advertiserId], references: [id])
  createdBy         User?            @relation(fields: [createdById], references: [id])
  devices           DeviceCampaign[]
  media             Media[]          @relation("MediaCampaign")
  mediaAssets       MediaAsset[]
  targets           PlaylistItem[]
  playlists         Playlist[]
  videos            Video[]
  targetDrivers     Driver[]         @relation("CampaignToDriver")

  @@index([active])
  @@index([status])
  @@index([startDate, endDate])
  @@map("campaigns")
}

model Playlist {
  id         String   @id @default(uuid())
  campaignId String   @map("campaign_id")
  name       String
  loopType   String   @default("SEQUENTIAL")
  createdAt  DateTime @default(now()) @map("created_at")
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@map("playlists")
}

model PlaylistItem {
  campaignId String   @map("campaign_id")
  deviceId   String   @map("device_id")
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  device     Device   @relation(fields: [deviceId], references: [deviceId], onDelete: Cascade)

  @@id([campaignId, deviceId])
  @@map("playlist_items")
}

model DeviceCampaign {
  device_id   String
  campaign_id String
  assigned_at DateTime @default(now())
  campaign    Campaign @relation(fields: [campaign_id], references: [id], onDelete: Cascade)
  device      Device   @relation(fields: [device_id], references: [id], onDelete: Cascade)

  @@id([device_id, campaign_id])
  @@index([device_id])
  @@index([campaign_id])
  @@map("device_campaigns")
}

model Media {
  id               String    @id @default(uuid())
  name             String?
  filename         String?
  originalFilename String?   @map("original_filename")
  mime_type        String?   @map("mime_type")
  mimeType         String?
  size             BigInt?
  fileSize         BigInt?   @map("file_size")
  durationSeconds  Int?      @map("duration_seconds")
  width            Int?
  height           Int?
  storageKey       String?   @map("storage_key")
  url              String?
  cdnUrl           String?   @map("cdn_url")
  hash             String?
  hashMd5          String?   @map("hash_md5")
  hashSha256       String?   @map("hash_sha256")
  campaign_id      String?
  status           String    @default("READY")
  createdAt        DateTime  @default(now()) @map("created_at")
  qrUrl            String?   @map("qr_url")
  campaign         Campaign? @relation("MediaCampaign", fields: [campaign_id], references: [id])

  @@index([status])
  @@map("media")
}

model AnalyticsEvent {
  id         String   @id @default(uuid())
  deviceId   String   @map("device_id")
  campaignId String?  @map("campaign_id")
  mediaId    String?  @map("media_id")
  eventType  String   @map("event_type")
  eventData  String?  @map("event_data")
  lat        Float?
  lng        Float?
  timestamp  DateTime @default(now())
  occurredAt DateTime @map("occurred_at")
  receivedAt DateTime @default(now()) @map("received_at")
  processed  Boolean  @default(false)
  device     Device   @relation(fields: [deviceId], references: [deviceId])

  @@index([deviceId])
  @@index([campaignId])
  @@index([eventType])
  @@index([occurredAt])
  @@index([processed])
  @@map("analytics_events")
}

model CampaignMetric {
  id                BigInt   @id @default(autoincrement())
  campaignId        String   @map("campaign_id")
  deviceId          String?  @map("device_id")
  date              DateTime
  city              String?
  totalImpressions  Int      @default(0) @map("total_impressions")
  totalCompletions  Int      @default(0) @map("total_completions")
  totalErrors       Int      @default(0) @map("total_errors")
  uniqueDevices     Int      @default(0) @map("unique_devices")
  avgCompletionRate Float?   @map("avg_completion_rate")
  createdAt         DateTime @default(now()) @map("created_at")
  campaign          Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  device            Device?  @relation(fields: [deviceId], references: [id])

  @@unique([campaignId, date, city])
  @@index([campaignId])
  @@index([date])
  @@map("campaign_metrics")
}

model DeviceCommand {
  id            String    @id @default(uuid())
  deviceId      String    @map("device_id")
  commandType   String    @map("command_type")
  commandParams String?   @map("command_params")
  status        String    @default("PENDING")
  createdAt     DateTime  @default(now()) @map("created_at")
  executedAt    DateTime? @map("executed_at")
  result        String?
  expiresAt     DateTime? @map("expires_at")
  device        Device    @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@index([deviceId])
  @@index([status])
  @@map("device_commands")
}

model Video {
  id         String   @id @default(uuid())
  campaignId String   @map("campaign_id")
  title      String
  url        String
  duration   Int
  fileSize   Int?     @map("file_size")
  mimeType   String?  @map("mime_type")
  createdAt  DateTime @default(now()) @map("created_at")
  uploadedAt DateTime @default(now()) @map("uploaded_at")
  qrUrl      String?  @map("qr_url")
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@map("videos")
}

model DeviceHeartbeat {
  id           String   @id @default(uuid())
  deviceId     String   @map("device_id")
  batteryLevel Int?     @map("battery_level")
  storageFree  String?  @map("storage_free")
  timestamp    DateTime @default(now())
  device       Device   @relation(fields: [deviceId], references: [deviceId], onDelete: Cascade)

  @@index([deviceId])
  @@map("device_heartbeats")
}

model PlaybackEvent {
  id        String   @id @default(uuid())
  deviceId  String   @map("device_id")
  eventType String   @map("event_type")
  videoId   String   @map("video_id")
  lat       Float?
  lng       Float?
  timestamp DateTime @default(now())
  device    Device   @relation(fields: [deviceId], references: [deviceId], onDelete: Cascade)

  @@index([deviceId])
  @@index([timestamp])
  @@index([videoId])
  @@map("playback_events")
}

model MediaAsset {
  id         String   @id @default(uuid())
  campaignId String   @map("campaign_id")
  type       String
  filename   String
  url        String
  fileSize   Int      @map("file_size")
  checksum   String
  duration   Int?
  version    Int      @default(1)
  createdAt  DateTime @default(now()) @map("created_at")
  qrUrl      String?  @map("qr_url")
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId])
  @@map("media_assets")
}

model Fleet {
  id        String   @id @default(uuid())
  name      String   @unique
  city      String?
  createdAt DateTime @default(now()) @map("created_at")

  @@map("fleets")
}

model Driver {
  id                  String           @id @default(uuid())
  fullName            String           @map("full_name")
  cedula              String?          @unique
  phone               String           @unique
  licensePlate        String?          @map("license_plate")
  taxiPlate           String?          @unique @map("taxi_plate")
  taxiNumber          String?          @map("taxi_number")
  subscriptionPaid    Boolean          @default(false) @map("subscription_paid")
  subscriptionEnd     DateTime?        @map("subscription_end")
  status              String           @default("ACTIVE")
  onboardedAt         DateTime         @default(now()) @map("onboarded_at")
  blockedAt           DateTime?        @map("blocked_at")
  createdAt           DateTime         @default(now()) @map("created_at")
  updatedAt           DateTime         @updatedAt @map("updated_at")
  referredBy          String?          @map("referred_by")
  password            String?
  referredAdvertisers Advertiser[]     @relation("AdvertiserReferrals")

  // LEGAL COMPLIANCE: Acceptance of agreements
  insuranceAccepted    Boolean   @default(false) @map("insurance_accepted")
  insuranceAcceptedAt  DateTime? @map("insurance_accepted_at")
  contractAccepted     Boolean   @default(false) @map("contract_accepted")
  contractAcceptedAt   DateTime? @map("contract_accepted_at")
  agreementVersion     String?   @map("agreement_version")
  devices             Device[]
  locations           DriverLocation[]
  referredByDriver    Driver?          @relation("DriverReferrals", fields: [referredBy], references: [id])
  referrals           Driver[]         @relation("DriverReferrals")
  payrollPayments     PayrollPayment[]
  subscriptions       Subscription[]
  campaigns           Campaign[]       @relation("CampaignToDriver")

  @@index([status])
  @@index([phone])
  @@map("drivers")
}

model FinancialTransaction {
  id        String   @id @default(uuid())
  type      String
  category  String
  amount    Float
  netAmount Float    @map("net_amount")
  taxAmount Float    @map("tax_amount")
  status    String   @default("PENDING")
  entityId  String?  @map("entity_id")
  reference String?  @unique
  note      String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([type])
  @@index([category])
  @@index([status])
  @@index([createdAt])
  @@map("financial_transactions")
}

model PayrollPayment {
  id           String    @id @default(uuid())
  driverId     String    @map("driver_id")
  amount       Float
  month        Int
  year         Int
  status       String    @default("PENDING")
  referenceNum String?   @map("reference_num")
  paidAt       DateTime? @map("paid_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  driver       Driver    @relation(fields: [driverId], references: [id], onDelete: Cascade)

  @@unique([driverId, month, year])
  @@index([driverId])
  @@index([status])
  @@map("payroll_payments")
}

model Subscription {
  id            String    @id @default(uuid())
  driverId      String    @map("driver_id")
  deviceId      String?   @map("device_id")
  plan          String
  amount        Float     @default(6000.0)
  status        String    @default("PENDING")
  startDate     DateTime  @default(now()) @map("start_date")
  dueDate       DateTime  @map("due_date")
  validUntil    DateTime  @map("valid_until")
  paidAt        DateTime? @map("paid_at")
  paymentMethod String?   @map("payment_method")
  notes         String?
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  device        Device?   @relation(fields: [deviceId], references: [deviceId], onDelete: Cascade)
  driver        Driver    @relation(fields: [driverId], references: [id], onDelete: Cascade)

  @@index([driverId])
  @@index([deviceId])
  @@index([status])
  @@index([dueDate])
  @@map("subscriptions")
}

model Advertiser {
  id             String          @id @default(uuid())
  companyName    String          @map("company_name")
  contactName    String          @map("contact_name")
  email          String          @unique
  phone          String?
  status         String          @default("ACTIVE")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")
  facebook       String?
  instagram      String?
  productsData   String?         @default("[]") @map("products_data")
  websiteUrl     String?         @map("website_url")
  whatsapp       String?
  category       String?         @default("General")
  pedidosYaUrl   String?         @map("pedidos_ya_url")
  uberEatsUrl    String?         @map("uber_eats_url")
  referredBy     String?         @map("referred_by")
  password       String?
  referrer       Driver?         @relation("AdvertiserReferrals", fields: [referredBy], references: [id])
  campaigns      Campaign[]
  portalRequests PortalRequest[]

  @@index([status])
  @@index([category])
  @@map("advertisers")
}

model PortalRequest {
  id           String     @id @default(uuid())
  advertiserId String     @map("advertiser_id")
  campaignId   String?    @map("campaign_id")
  type         String
  status       String     @default("PENDING")
  title        String
  description  String?
  data         String?    @default("{}")
  adminNotes   String?    @map("admin_notes")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")
  advertiser   Advertiser @relation(fields: [advertiserId], references: [id], onDelete: Cascade)

  @@index([advertiserId])
  @@index([status])
  @@index([type])
  @@map("portal_requests")
}

model DriverLocation {
  id        String   @id @default(uuid())
  driverId  String   @map("driver_id")
  deviceId  String   @map("device_id")
  latitude  Float
  longitude Float
  speed     Float    @default(0)
  timestamp DateTime @default(now())
  device    Device   @relation(fields: [deviceId], references: [deviceId], onDelete: Cascade)
  driver    Driver   @relation(fields: [driverId], references: [id], onDelete: Cascade)

  @@index([deviceId, timestamp])
  @@index([driverId, timestamp])
  @@index([driverId])
  @@map("driver_locations")
}

model Notification {
  id        String   @id @default(uuid())
  title     String
  message   String
  type      String   @default("INFO")
  category  String   @default("SYSTEM")
  read      Boolean  @default(false)
  entityId  String?  @map("entity_id")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([read])
  @@index([category])
  @@index([createdAt])
  @@map("notifications")
}
