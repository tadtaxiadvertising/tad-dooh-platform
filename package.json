{
  "name": "tad-dooh-platform",
  "version": "0.1.0",
  "description": "Taxi Advertising Distribution - Digital Out-Of-Home Network",
  "author": "TAD Dominicana",
  "license": "PROPRIETARY",
  "private": true,
  "workspaces": [
    "admin-dashboard",
    "backend"
  ],
  "scripts": {
    "dev:backend": "cd backend && npm run start:dev",
    "dev:tablet": "cd tablet-player && python -m http.server 8080",
    "dev:admin": "npm run dev -w admin-dashboard",
    "install:all": "npm install",
    "build": "next build",
    "build:backend": "cd backend && npm run build",
    "deploy:vercel": "node devops/deploy-vercel.js"
  },
  "keywords": [
    "dooh",
    "advertising",
    "taxi",
    "digital-signage",
    "offline-first"
  ],
  "dependencies": {
    "@nestjs/common": "^11.1.16",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.16",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.16",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/client": "^7.5.0",
    "@supabase/supabase-js": "^2.99.1",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.4",
    "express": "^5.2.1",
    "next": "15.1.7",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "prisma": "^7.5.0",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.1",
    "postcss": "^8.5.8"
  }
}
