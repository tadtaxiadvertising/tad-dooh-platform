{
  "name": "tad-dooh-platform",
  "version": "0.1.0",
  "description": "Taxi Advertising Distribution - Digital Out-Of-Home Network",
  "author": "TAD Dominicana",
  "license": "PROPRIETARY",
  "private": true,
  "workspaces": [
    "admin-dashboard",
    "backend"
  ],
  "scripts": {
    "dev:backend": "cd backend && npm run start:dev",
    "dev:tablet": "cd tablet-player && python -m http.server 8080",
    "install:all": "npm install",
    "build": "npm run build -w admin-dashboard && mv admin-dashboard/.next .next && npm run build -w backend",
    "build:backend": "cd backend && npm run build",
    "vercel-build": "npm run build:backend",
    "deploy:vercel": "node devops/deploy-vercel.js"
  },
  "keywords": [
    "dooh",
    "advertising",
    "taxi",
    "digital-signage",
    "offline-first"
  ],
  "dependencies": {
    "@nestjs/common": "^11.1.16",
    "@nestjs/core": "^11.1.16",
    "@nestjs/platform-express": "^11.1.16",
    "express": "^5.2.1",
    "next": "15.1.7",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.1",
    "postcss": "^8.5.8"
  }
}
